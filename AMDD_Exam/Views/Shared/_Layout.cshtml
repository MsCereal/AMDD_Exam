<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AMDD Skills Exam</title>
    <link rel="icon" type="image/png" href="~/favicon.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <!-- Navbar -->
    <nav class="amdd-navbar d-flex align-items-center navbar-dark no-print">
        <a asp-controller="Exam" asp-action="Index"
           class="d-flex align-items-center gap-2 text-white text-decoration-none fw-bold"
           style="font-size:1rem;flex-shrink:0;">
            <img src="~/favicon.png" alt="AMDD"
                 style="width:26px;height:26px;filter:brightness(0) invert(1);" />
            AMDD Skills Exam
        </a>
        <span class="flex-grow-1 text-center d-none d-md-block"
              style="color:#d9b8ff;font-size:0.85rem;">
            Branch Banking Application Development Unit
        </span>
        <a asp-controller="Exam" asp-action="ReviewerLogin"
           style="background:var(--amdd-600);color:#fff;border:none;
                  font-size:0.8rem;padding:6px 16px;border-radius:6px;
                  white-space:nowrap;flex-shrink:0;text-decoration:none;">
            🔍 Reviewer
        </a>
    </nav>

    <!-- Main content -->
    <main class="container py-4">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="footer no-print">
        <div class="container">
            <div style="color:var(--amdd-400);">
                &copy; @DateTime.Now.Year — Branch Banking Application Development Unit &mdash; Internal Use Only
            </div>
            <div style="color:var(--amdd-600);font-size:0.72rem;margin-top:2px;">
                Made with 💜 by <em>cutiepatootiechechebureche</em> xd
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
